[
  {
    "type": "REGEX",
    "name": "Contract Number",
    "description": "Detects contract and agreement reference numbers",
    "disableCategory": false,
    "value": "(Contract|Agreement)\\s*(No\\.?|Number|#)[:\\s]*([A-Z0-9]{4,15})",
