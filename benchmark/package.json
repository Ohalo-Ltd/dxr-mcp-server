{
  "name": "dxr-benchmark",
  "version": "1.0.0",
  "description": "Benchmark framework for DXR MCP Server - comparing AI agent performance with vs without Data X-Ray",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dxr-benchmark": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "benchmark": "tsx src/index.ts run",
    "benchmark:mock": "tsx src/index.ts run --mock",
    "benchmark:live": "tsx src/index.ts run --live",
    "report": "tsx src/index.ts report",
    "validate": "tsx src/index.ts validate",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.35.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^17.2.4",
    "ora": "^8.0.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
